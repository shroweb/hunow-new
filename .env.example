DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
SITE_URL=https://your-domain.com
ADMIN_EMAILS=your@email.com

# Required for newsletter + transactional emails (get a key at resend.com)
RESEND_API_KEY=re_...
NEWSLETTER_FROM=HU NOW <newsletter@your-domain.com>
EMAIL_FROM=HU NOW <hello@your-domain.com>

# Required for image/avatar uploads (connect a Blob store in Vercel Storage)
# BLOB_READ_WRITE_TOKEN=vercel_blob_...

# Cron job secret — set in Vercel env vars and vercel.json Authorization header
# CRON_SECRET=a_long_random_string

# Set to true to prevent public self-registration (only ADMIN_EMAILS can sign up)
# DISABLE_SELF_REGISTRATION=false

# Optional: Skiddle API key for event imports (free at skiddle.com/api)
# SKIDDLE_API_KEY=your_key
