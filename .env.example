DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
SITE_URL=https://your-domain.com
ADMIN_EMAILS=your@email.com
APP_JWT_SECRET=replace_with_a_long_random_secret_for_the_mobile_app

# Required for newsletter + transactional emails (get a key at resend.com)
RESEND_API_KEY=re_...
NEWSLETTER_FROM=HU NOW <newsletter@your-domain.com>
EMAIL_FROM=HU NOW <hello@your-domain.com>

# Optional: post server error payloads to a webhook/Sentry-compatible intake
# ERROR_WEBHOOK_URL=https://...
# SENTRY_WEBHOOK_URL=https://...

# Required for image/avatar uploads (connect a Blob store in Vercel Storage)
# BLOB_READ_WRITE_TOKEN=vercel_blob_...

# Cron job secret — set in Vercel env vars and vercel.json Authorization header
# CRON_SECRET=a_long_random_string

# Set to true to prevent public self-registration (only ADMIN_EMAILS can sign up)
# DISABLE_SELF_REGISTRATION=false

# Demo seed content is enabled by default in local dev and disabled by default in production.
# Set true only if you deliberately want the demo Hull content in a new production DB.
# HUNOW_ENABLE_DEMO_SEED=false

# Full-store snapshot saves are disabled in production unless explicitly enabled.
# Normal admin pages use targeted record writes instead.
# HUNOW_ALLOW_FULL_STORE_SAVE=false

# Optional: Skiddle API key for event imports (free at skiddle.com/api)
# SKIDDLE_API_KEY=your_key
